{
  "name": "agent-monitor",
  "displayName": "Agent Monitor",
  "description": "Live sidebar for the Cursor Agent: timeline + session/turn/tool tree, fed by the agent-monitor hooks. Zero network, all local.",
  "version": "0.1.0",
  "publisher": "agent-monitor",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Halo-Welt/agent-monitor.git" },
  "engines": { "vscode": "^1.84.0" },
  "categories": ["Visualization", "Other"],
  "keywords": ["observability", "hooks", "agent", "monitoring", "cursor"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentMonitor",
          "title": "Agent Monitor",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentMonitor": [
        {
          "type": "webview",
          "id": "agentMonitor.panel",
          "name": "Agent Monitor"
        }
      ]
    },
    "commands": [
      {
        "command": "agentMonitor.reveal",
        "title": "Agent Monitor: Focus Panel"
      }
    ]
  },
  "activationEvents": ["onStartupFinished"],
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "vscode:prepublish": "node esbuild.mjs --production",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.84.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.6.0"
  }
}
